# Database Configuration (Required)
# Get a free PostgreSQL database from Neon: https://neon.tech
DATABASE_URL=postgresql://username:password@host:port/database_name

# OpenAI API Configuration (Required for AI features)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Server Configuration (Optional)
# Port where the application will run (default: 80, recommended: 5000 for development)
PORT=5000
NODE_ENV=development

# Redis Configuration (Optional - for caching in production)
# Only needed for production with caching enabled
# REDIS_URL=redis://localhost:6379

# Social Media API Keys (Future Integration - Optional)
# These will be used for actual posting to social media platforms
# META_ACCESS_TOKEN=your_meta_access_token
# TWITTER_API_KEY=your_twitter_api_key
# TIKTOK_ACCESS_TOKEN=your_tiktok_access_token